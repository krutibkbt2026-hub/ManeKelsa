<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardBackgroundColor="#FFFFFF"
            card_view:cardCornerRadius="20dp"
            card_view:cardElevation="6dp"
            card_view:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Worker Image -->
                <ImageView
                    android:id="@+id/imageDetailWorker"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="center"
                    android:background="#E0E0E0"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_camera" />

                <!-- Worker Name -->
                <TextView
                    android:id="@+id/textDetailName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Worker Name"
                    android:textColor="#6A1B9A"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <!-- Work -->
                <TextView
                    android:id="@+id/textDetailWork"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Work"
                    android:textColor="#212121"
                    android:textSize="20sp" />

                <!-- Experience -->
                <TextView
                    android:id="@+id/textDetailExperience"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Experience"
                    android:textColor="#212121"
                    android:textSize="20sp" />

                <!-- Phone -->
                <TextView
                    android:id="@+id/textDetailPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Phone"
                    android:textColor="#212121"
                    android:textSize="20sp" />

                <!-- Area -->
                <TextView
                    android:id="@+id/textDetailArea"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Area"
                    android:textColor="#212121"
                    android:textSize="20sp" />

                <!-- Call Worker Button -->
                <Button
                    android:id="@+id/btnCallWorker"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="32dp"
                    android:backgroundTint="#7B1FA2"
                    android:text="@string/call_worker"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Edit Worker Button -->
                <Button
                    android:id="@+id/btnEditWorker"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="#1976D2"
                    android:text="Edit Worker"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>